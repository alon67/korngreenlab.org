---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  essays,
  essaySections,
  letters,
  lettersSection,
  podcasts,
  podcastsSection,
} from "../data/essays";

const dateFormatter = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
  timeZone: "UTC",
});

function formatDate(iso) {
  return dateFormatter.format(new Date(`${iso}T00:00:00Z`));
}

// Group essays by category and order each group newest-first.
const sections = essaySections.map((section) => ({
  ...section,
  items: essays
    .filter((essay) => essay.category === section.key)
    .sort((a, b) => b.date.localeCompare(a.date)),
}));

const pressLetters = [...letters].sort((a, b) => b.date.localeCompare(a.date));
const podcastEpisodes = [...podcasts].sort((a, b) => b.date.localeCompare(a.date));

const zmanAuthorUrl = "https://www.zman.co.il/writer/30378/";
---

<BaseLayout
  title="Essays and Public Writing | Alon Korngreen"
  description="Selected essays by Alon Korngreen on science, technology, Israeli society, photography and public life."
>
  <div class="page-header">
    <h1>Essays and Public Writing</h1>
  </div>

  <div class="essays-intro">
    <p>
      Alongside my scientific work, I write essays in Hebrew on science, technology,
      Israeli society, photography and public life. These articles reflect my personal
      views and do not represent the Korngreen Lab, its members or Bar-Ilan University.
    </p>
  </div>

  <div class="essays-content">
    {sections.map((section) => (
      <section class="essay-section" aria-labelledby={`section-${section.key}`}>
        <h2 id={`section-${section.key}`}>{section.heading}</h2>
        <p class="essay-section-blurb">{section.blurb}</p>
        <ul class="essay-list">
          {section.items.map((essay) => (
            <li class="essay-item">
              <a
                class="essay-title"
                href={essay.url}
                target="_blank"
                rel="noopener noreferrer"
                lang="he"
                dir="rtl"
              >
                {essay.title}
              </a>
              <time class="essay-date" datetime={essay.date} dir="ltr">
                {formatDate(essay.date)}
              </time>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>

  <div class="essays-outro">
    <p class="essays-outro-link">
      <a href={zmanAuthorUrl} target="_blank" rel="noopener noreferrer">
        View my most recent posts at Zman Israel
      </a>
    </p>
    <p class="essays-note">
      Zman Israel&rsquo;s author page may display only a limited selection of recent
      posts. The Zman Israel essays above provide a curated archive.
    </p>
  </div>

  {pressLetters.length > 0 && (
    <div class="essays-content">
      <section class="essay-section" aria-labelledby="section-letters">
        <h2 id="section-letters">{lettersSection.heading}</h2>
        <p class="essay-section-blurb">{lettersSection.blurb}</p>
        <ul class="essay-list">
          {pressLetters.map((letter) => (
            <li class="essay-item">
              <a
                class="essay-title"
                href={letter.url}
                target="_blank"
                rel="noopener noreferrer"
                lang="he"
                dir="rtl"
              >
                {letter.title}
              </a>
              <span class="essay-meta">
                <span class="essay-source">{letter.publication}</span>
                <time class="essay-date" datetime={letter.date} dir="ltr">
                  {formatDate(letter.date)}
                </time>
              </span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  )}

  {podcastEpisodes.length > 0 && (
    <div class="essays-content">
      <section class="essay-section" aria-labelledby="section-podcasts">
        <h2 id="section-podcasts">{podcastsSection.heading}</h2>
        <p class="essay-section-blurb">{podcastsSection.blurb}</p>
        <ul class="essay-list">
          {podcastEpisodes.map((episode) => (
            <li class="essay-item">
              <a
                class="essay-title"
                href={episode.url}
                target="_blank"
                rel="noopener noreferrer"
                lang="he"
                dir="rtl"
              >
                {episode.title}
              </a>
              <span class="essay-meta">
                <span class="essay-source" lang="he" dir="rtl">{episode.show}</span>
                <time class="essay-date" datetime={episode.date} dir="ltr">
                  {formatDate(episode.date)}
                </time>
              </span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  )}
</BaseLayout>
